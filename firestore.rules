rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isHouseMember() {
      // ทุกคนที่ล็อกอินสำเร็จถือเป็นสมาชิกบ้าน (บ้านนี้มีแค่ 3 คนที่รู้จักกันเอง)
      return isSignedIn();
    }

    // ---------- users / profiles ----------
    // users/{uid} เก็บโปรไฟล์ที่ทุกคนต้องเห็นชื่อกัน (แสดงผู้ดำเนินการ) แต่แก้ได้เฉพาะเจ้าของ
    match /users/{uid} {
      allow read: if isHouseMember();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    // ---------- PRIVATE: ข้อมูลรายรับรายจ่ายส่วนตัว ----------
    // privateFinance/{uid}/wallets/{walletId}
    match /privateFinance/{uid}/{document=**} {
      allow read, write: if isOwner(uid);
    }

    // ---------- SHARED: ของใช้ภายในบ้าน ----------
    match /houseInventory/{document=**} {
      allow read, write: if isHouseMember();
    }
    match /categories/{document=**} {
      allow read, write: if isHouseMember();
    }
    match /items/{itemId} {
      allow read, write: if isHouseMember();
    }
    match /itemHistory/{document=**} {
      allow read: if isHouseMember();
      allow create: if isHouseMember();
      allow update, delete: if false; // ประวัติแก้ไม่ได้ ลบไม่ได้
    }

    // ---------- SHARED: รายจ่ายร่วม 3 คน ----------
    match /sharedExpenses/{document=**} {
      allow read, write: if isHouseMember();
    }

    // ---------- SHARED: สรุปรายเดือน (คำนวณรวมจาก client / cloud function) ----------
    match /monthlySummary/{document=**} {
      allow read: if isHouseMember();
      allow write: if isHouseMember();
    }

    match /dailySummary/{uid}/{document=**} {
      allow read, write: if isOwner(uid);
    }

    // ---------- notifications / fcm tokens ----------
    match /fcmTokens/{uid} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid);
    }
    match /notifications/{document=**} {
      allow read: if isHouseMember();
      allow create: if isHouseMember();
    }
  }
}
